generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
  video
}

enum ShareTokenType {
  worker_receipt
  customer_receipt
  customer_item
  public_evidence
  public_master
}

enum UserRole {
  admin
  worker
  customer
}

model User {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String

  role       UserRole
  name       String
  active     Boolean  @default(true)

  created_at DateTime @default(now())

  @@index([tenant_id, company_id])
  @@index([role])
}

model Receipt {
  id               String        @id @default(uuid())
  tenant_id        String
  company_id       String

  receipt_no       String
  supplier_name    String?

  status           ReceiptStatus @default(pending)
  total_items      Int           @default(0)
  completed_items  Int           @default(0)
  progress_percent Float         @default(0)

  locked           Boolean       @default(false)
  version          Int           @default(0)

  created_at       DateTime      @default(now())
  created_by       String?
  last_activity_at DateTime      @default(now())

  // relations
  items            ReceiptItem[]
  evidences        Evidence[]
  logs             ScanLog[]
  shareTokens      ShareToken[]
  masterSources    MasterReceiptSource[]

  @@unique([tenant_id, company_id, receipt_no])
  @@index([tenant_id, company_id])
  @@index([receipt_no])
  @@index([status])
}

model ReceiptItem {
  id              String     @id @default(uuid())
  tenant_id       String
  company_id      String

  receipt_id      String
  receipt         Receipt    @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  sku             String
  barcode         String

  name_zh         String
  name_es         String

  // 你要求的维度
  case_pack       Int?       // 中包数
  expected_qty    Int        // 商品总数量（应验）
  good_qty        Int        @default(0)
  damaged_qty     Int        @default(0)

  sell_price      Decimal?   @db.Numeric(12, 2)
  discount        Decimal?   @db.Numeric(12, 2)
  line_total      Decimal?   @db.Numeric(14, 2)

  // 扩展：非清单到货
  unexpected      Boolean    @default(false)

  status          ItemStatus @default(pending)
  locked          Boolean    @default(false)
  evidence_count  Int        @default(0)

  last_updated_at DateTime   @default(now())
  last_updated_by String?
  version         Int        @default(0)

  // relations
  evidences        Evidence[]
  logs             ScanLog[]

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([sku])
  @@index([barcode])
  @@unique([tenant_id, company_id, receipt_id, sku])
}

model Evidence {
  id         String       @id @default(uuid())
  tenant_id  String
  company_id String

  receipt_id String
  receipt    Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  item_id    String?
  item       ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  type       EvidenceType @default(photo)
  file_url   String
  file_size  Int
  mime_type  String
  checksum   String

  created_at DateTime     @default(now())
  created_by String?

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
}

model ScanLog {
  id          String       @id @default(uuid())
  tenant_id   String
  company_id  String

  receipt_id  String
  receipt     Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  item_id     String?
  item        ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  action_type String
  before_value Json?
  after_value  Json?

  operator_id String?
  device_id   String?

  created_at  DateTime     @default(now())

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
  @@index([created_at])
}

model ShareToken {
  id          String        @id @default(uuid())
  tenant_id   String
  company_id  String

  token       String        @unique
  type        ShareTokenType
  permission  String        @default("read_only")

  receipt_id  String?
  receipt     Receipt?      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  item_id     String?
  item        ReceiptItem?   @relation(fields: [item_id], references: [id], onDelete: SetNull)

  expires_at  DateTime?
  active      Boolean       @default(true)

  created_at  DateTime      @default(now())
  created_by  String?

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
}

model MasterReceipt {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String

  master_no  String   @unique
  status     String   @default("draft")

  created_at DateTime @default(now())
  created_by String?

  // relations
  sources    MasterReceiptSource[]
  shareLinks MasterShareLink[]

  @@index([tenant_id, company_id])
}

model MasterReceiptSource {
  id         String  @id @default(uuid())
  tenant_id  String
  company_id String

  master_id  String
  master     MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  receipt_id String
  receipt    Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, master_id, receipt_id])
  @@index([tenant_id, company_id])
  @@index([master_id])
  @@index([receipt_id])
}

model MasterShareLink {
  id              String   @id @default(uuid())
  tenant_id        String
  company_id       String

  share_public_id  String   @unique
  master_id        String
  master           MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  active           Boolean  @default(true)
  expires_at       DateTime?

  created_at       DateTime @default(now())
  created_by       String?

  @@index([tenant_id, company_id])
  @@index([master_id])
}

model IdempotencyRecord {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String

  key        String
  request_hash String
  status     String   @default("processing")
  response_json Json?

  created_at DateTime @default(now())

  @@unique([tenant_id, company_id, key])
  @@index([tenant_id, company_id])
  @@index([created_at])
}

model ImportBatch {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String

  receipt_id String?
  status     String   @default("draft") // draft/validated/committed/failed

  filename   String?
  file_hash  String?

  created_at DateTime @default(now())
  created_by String?

  exceptions ImportException[]

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([status])
}

model ImportException {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String

  batch_id   String
  batch      ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  row_no     Int
  field      String
  message    String

  created_at DateTime @default(now())

  @@index([tenant_id, company_id])
  @@index([batch_id])
}
