generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  worker
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
}

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @default("default")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  companies            Company[]
  users                User[]
  receipts             Receipt[]
  receiptItems         ReceiptItem[]
  evidences            Evidence[]
  scanLogs             ScanLog[]
  idempotencyRecords   IdempotencyRecord[]
  importBatches        ImportBatch[]
  shareTokens          ShareToken[]
  masterReceipts       MasterReceipt[]
  masterReceiptSources MasterReceiptSource[]
  masterShareLinks     MasterShareLink[]

  ygOrderImports       YgOrderImport[]
  ygSupplierOrders     YgSupplierOrder[]
  ygSupplierOrderItems YgSupplierOrderItemS[]
  productCatalogs      ProductCatalog[]
  productImportBatches ProductImportBatch[]
  yogoProductSources   YogoProductSource[]
  yogoProductSyncLogs  YogoProductSyncLog[]
  userPermissions      UserPermission[]
  suppliers            SupplierProfile[]
  customers            CustomerProfile[]
  catalogConfigs       CatalogConfig[]
  categoryMaps         ProductCategoryMap[]
}

model Company {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String   @default("default")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  users                User[]
  receipts             Receipt[]
  receiptItems         ReceiptItem[]
  evidences            Evidence[]
  scanLogs             ScanLog[]
  idempotencyRecords   IdempotencyRecord[]
  importBatches        ImportBatch[]
  shareTokens          ShareToken[]
  masterReceipts       MasterReceipt[]
  masterReceiptSources MasterReceiptSource[]
  masterShareLinks     MasterShareLink[]

  ygOrderImports       YgOrderImport[]
  ygSupplierOrders     YgSupplierOrder[]
  ygSupplierOrderItems YgSupplierOrderItemS[]
  productCatalogs      ProductCatalog[]
  productImportBatches ProductImportBatch[]
  yogoProductSources   YogoProductSource[]
  yogoProductSyncLogs  YogoProductSyncLog[]
  userPermissions      UserPermission[]
  suppliers            SupplierProfile[]
  customers            CustomerProfile[]
  catalogConfigs       CatalogConfig[]
  categoryMaps         ProductCategoryMap[]

  @@index([tenant_id])
}

model User {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  user_id       String
  name          String
  phone         String
  email         String?
  avatar_url    String?
  password_hash String
  role          Role    @default(worker)
  active        Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company    Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  permission UserPermission?

  @@unique([tenant_id, company_id, user_id])
  @@unique([tenant_id, company_id, name])
  @@unique([tenant_id, company_id, phone])
  @@index([tenant_id, company_id])
}

model UserPermission {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  user_id    String @unique @db.Uuid

  manage_suppliers       Boolean @default(true)
  manage_products        Boolean @default(true)
  manage_customers       Boolean @default(true)
  export_product_catalog Boolean @default(true)
  view_reports           Boolean @default(true)
  inspect_goods          Boolean @default(true)
  import_receipts        Boolean @default(true)
  export_all_data        Boolean @default(false)
  view_all_data          Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, user_id])
  @@index([tenant_id, company_id])
  @@map("user_permissions")
}

model SupplierProfile {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  short_name          String
  full_name           String
  logo_url            String?
  contact_name        String?
  phone               String?
  address             String?
  category_discounts  String?
  cooperate_start_at  DateTime?
  account_period_days Int?
  enabled             Boolean   @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([short_name])
  @@map("supplier_profiles")
}

model CustomerProfile {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  name            String
  contact_name    String?
  mobile          String?
  whatsapp        String?
  email           String?
  store_addresses String?
  city_country    String?
  customer_type   String?
  vip_level       String?
  credit_level    String?
  tag_text        String?
  order_stat_text String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([name])
  @@map("customer_profiles")
}

model CatalogConfig {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  customer          String?
  category          String?
  discount          String?
  show_stock        Boolean @default(true)
  show_image        Boolean @default(true)
  language          String  @default("zh")
  cover_url         String?
  note              String?
  doc_header        String?
  doc_footer        String?
  doc_phone         String?
  doc_logo_url      String?
  doc_logo_position String  @default("right")
  doc_header_align  String  @default("left")
  doc_footer_align  String  @default("right")
  doc_whatsapp      String?
  doc_wechat        String?
  doc_show_whatsapp Boolean @default(false)
  doc_show_wechat   Boolean @default(false)
  doc_show_contact  Boolean @default(true)
  doc_show_header   Boolean @default(true)
  doc_show_footer   Boolean @default(true)
  doc_show_logo     Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id])
  @@index([tenant_id, company_id])
  @@map("catalog_configs")
}

model ProductCategoryMap {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  category_zh String
  category_es String?
  active      Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, category_zh])
  @@index([tenant_id, company_id])
  @@map("product_category_maps")
}

model Receipt {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  receipt_no    String
  supplier_name String?
  status        ReceiptStatus @default(pending)

  total_items      Int       @default(0)
  completed_items  Int       @default(0)
  progress_percent Float     @default(0)
  locked           Boolean   @default(false)
  last_activity_at DateTime?

  public_share_id String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  items            ReceiptItem[]
  evidences        Evidence[]
  logs             ScanLog[]
  importBatches    ImportBatch[]
  shareTokens      ShareToken[]
  masterSources    MasterReceiptSource[]
  receiptEvidences ReceiptEvidence[]     @relation("ReceiptToReceiptEvidence")

  @@index([tenant_id, company_id])
  @@index([receipt_no])
}

model ReceiptItem {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  receipt_id String @db.Uuid

  sku     String
  barcode String?
  name_zh String?
  name_es String?

  case_pack Int? @default(0)

  expected_qty Int @default(0)
  good_qty     Int @default(0)
  damaged_qty  Int @default(0)
  excess_qty   Int @default(0)

  sell_price      Decimal? @db.Decimal(12, 2)
  discount        Decimal? @db.Decimal(12, 2)
  normal_discount Decimal? @db.Decimal(12, 2)
  vip_discount    Decimal? @db.Decimal(12, 2)
  line_total      Decimal? @db.Decimal(14, 2)

  status     ItemStatus @default(pending)
  unexpected Boolean    @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  receipt Receipt @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  evidences   Evidence[]
  logs        ScanLog[]
  shareTokens ShareToken[]

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([sku])
}

model Evidence {
  id         String  @id @default(uuid()) @db.Uuid
  tenant_id  String  @db.Uuid
  company_id String  @db.Uuid
  receipt_id String  @db.Uuid
  item_id    String? @db.Uuid

  type      EvidenceType @default(photo)
  file_url  String
  file_size Int
  mime_type String
  checksum  String?

  created_by String?
  created_at DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  receipt Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item    ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
}

model ScanLog {
  id         String  @id @default(uuid()) @db.Uuid
  tenant_id  String  @db.Uuid
  company_id String  @db.Uuid
  receipt_id String  @db.Uuid
  item_id    String? @db.Uuid

  action  String  @default("scan")
  message String?

  sku     String?
  barcode String?

  good_qty    Int?
  damaged_qty Int?

  created_by String?
  device_id  String?

  created_at DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  receipt Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item    ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
  @@index([created_at])
}

model IdempotencyRecord {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  key          String
  request_hash String

  status_code   Int?
  response_json String?

  created_at DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, key, request_hash])
  @@index([tenant_id, company_id])
  @@index([created_at])
}

model ImportBatch {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  receipt_id String @db.Uuid

  status      String  @default("pending")
  result_json String?

  created_at DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  receipt Receipt @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([receipt_id])
}

model ShareToken {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  public_share_id String  @unique
  receipt_id      String  @db.Uuid
  item_id         String? @db.Uuid

  active     Boolean   @default(true)
  expires_at DateTime?
  created_at DateTime  @default(now())

  tenant  Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  receipt Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item    ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id])
  @@index([receipt_id])
}

model MasterReceipt {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  master_no String @unique
  status    String @default("open")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  sources    MasterReceiptSource[]
  shareLinks MasterShareLink[]

  @@index([tenant_id, company_id])
}

model MasterReceiptSource {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  master_id  String @db.Uuid
  receipt_id String @db.Uuid

  created_at DateTime @default(now())

  tenant  Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  master  MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)
  receipt Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@unique([master_id, receipt_id])
  @@index([tenant_id, company_id])
  @@index([receipt_id])
}

model MasterShareLink {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  master_id  String @db.Uuid

  share_public_id String    @unique
  active          Boolean   @default(true)
  expires_at      DateTime?
  created_at      DateTime  @default(now())

  tenant  Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  master  MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([master_id])
}

model ReceiptEvidence {
  id         String   @id @default(cuid())
  receipt_id String   @db.Uuid
  file_name  String
  mime_type  String?
  file_size  Int?
  image_data String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  receipt Receipt @relation("ReceiptToReceiptEvidence", fields: [receipt_id], references: [id], onDelete: Cascade)

  @@index([receipt_id])
}

model YgOrderImport {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  order_no         String
  source_file_name String
  sheet_name       String
  order_amount     Decimal? @db.Decimal(14, 2)
  last_three       String

  company_name  String?
  customer_name String?
  contact_name  String?
  contact_phone String?
  address_text  String?
  order_remark  String?
  store_label   String?

  supplier_count Int @default(0)
  item_count     Int @default(0)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  supplierOrders YgSupplierOrder[]

  @@unique([tenant_id, company_id, order_no])
  @@index([tenant_id, company_id])
  @@index([created_at])
  @@map("yg_order_imports")
}

model YgSupplierOrder {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid
  import_id  String @db.Uuid

  order_no         String
  supplier_code    String
  derived_order_no String
  order_amount     Decimal? @db.Decimal(14, 2)
  note_text        String?

  item_count Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  import  YgOrderImport @relation(fields: [import_id], references: [id], onDelete: Cascade)

  items YgSupplierOrderItemS[]

  @@index([tenant_id, company_id])
  @@index([import_id])
  @@index([supplier_code])
  @@map("yg_supplier_orders")
}

model YgSupplierOrderItemS {
  id                String @id @default(uuid()) @db.Uuid
  tenant_id         String @db.Uuid
  company_id        String @db.Uuid
  supplier_order_id String @db.Uuid

  line_no       Int
  location      String
  item_no       String?
  barcode       String?
  product_name  String?
  total_qty     Int      @default(0)
  unit_price    Decimal? @db.Decimal(14, 2)
  line_total    Decimal? @db.Decimal(14, 2)
  image_formula String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company       Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  supplierOrder YgSupplierOrder @relation(fields: [supplier_order_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([supplier_order_id])
  @@index([location])
  @@map("yg_supplier_order_items")
}

model ProductCatalog {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  sku     String
  barcode String?

  name_zh String?
  name_es String?

  case_pack   Int?
  carton_pack Int?

  price             Decimal? @db.Decimal(14, 2)
  normal_discount   Decimal? @db.Decimal(8, 4)
  vip_discount      Decimal? @db.Decimal(8, 4)
  category          String?
  supplier          String?
  available         Int      @default(0)
  status_text       String   @default("上架")
  is_new_product    Boolean  @default(true)
  changed_fields    Json?
  inventory         Int?
  last_import_batch String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, sku])
  @@index([tenant_id, company_id])
  @@index([updated_at])
  @@map("product_catalogs")
}

model ProductImportBatch {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  source_file_name String
  stored_file_path String?
  total_rows       Int     @default(0)
  created_count    Int     @default(0)
  changed_count    Int     @default(0)
  unchanged_count  Int     @default(0)
  on_shelf_count   Int     @default(0)
  off_shelf_count  Int     @default(0)

  created_by String?
  created_at DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([created_at])
  @@map("product_import_batches")
}

model YogoProductSource {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  source            String    @default("yogo")
  product_code      String
  product_no        String?
  name_cn           String?
  name_es           String?
  category_id       String?
  category_name     String?
  subcategory_id    String?
  subcategory_name  String?
  supplier          String?
  source_price      Decimal?  @db.Decimal(14, 2)
  source_discount   Decimal?  @db.Decimal(8, 4)
  source_disabled   Boolean   @default(false)
  source_updated_at DateTime?
  synced_at         DateTime?
  last_received_at  DateTime  @default(now())

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, product_code])
  @@index([tenant_id, company_id])
  @@index([product_code])
  @@index([source_updated_at])
  @@index([updated_at])
  @@map("yogo_product_sources")
}

model YogoProductSyncLog {
  id         String @id @default(uuid()) @db.Uuid
  tenant_id  String @db.Uuid
  company_id String @db.Uuid

  source        String?
  request_id    String
  total_count   Int     @default(0)
  created_count Int     @default(0)
  updated_count Int     @default(0)
  failed_count  Int     @default(0)
  status        String  @default("success")
  error_message String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([request_id])
  @@index([tenant_id, company_id])
  @@index([created_at])
  @@map("yogo_product_sync_logs")
}
