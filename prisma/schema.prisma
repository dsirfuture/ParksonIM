generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  worker
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
  file
}

enum ImportStatus {
  draft
  validated
  committed
  failed
}

enum JobStatus {
  pending
  running
  done
  failed
}

enum MasterStatus {
  draft
  completed
}

enum ShareScope {
  receipt
  master
}

enum SharePermission {
  read
}

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  created_at DateTime @default(now())

  companies Company[]
  users     User[]
}

model Company {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  created_at DateTime @default(now())

  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users         User[]
  receipts      Receipt[]
  masterReceipts MasterReceipt[]

  @@index([tenant_id])
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid
  user_id    String
  name       String?
  role       UserRole @default(worker)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, user_id])
  @@index([tenant_id, company_id, role])
}

model Receipt {
  id              String        @id @default(uuid()) @db.Uuid
  tenant_id        String        @db.Uuid
  company_id       String        @db.Uuid
  receipt_no       String
  supplier_name    String?
  status           ReceiptStatus @default(pending)
  locked           Boolean       @default(false)

  total_items      Int           @default(0)
  completed_items  Int           @default(0)
  progress_percent Float         @default(0)

  last_activity_at DateTime      @default(now())
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  items        ReceiptItem[]
  evidences    Evidence[]
  logs         ScanLog[]
  shareTokens  ShareToken[]
  importBatches ImportBatch[]
  masterSources MasterReceiptSource[]

  @@unique([tenant_id, company_id, receipt_no])
  @@index([tenant_id, company_id, status])
}

model ReceiptItem {
  id           String     @id @default(uuid()) @db.Uuid
  tenant_id    String     @db.Uuid
  company_id   String     @db.Uuid
  receipt_id   String     @db.Uuid

  sku          String
  barcode      String?
  name_zh      String?
  name_es      String?
  case_pack    Int?

  expected_qty Int        @default(0)
  good_qty     Int        @default(0)
  damaged_qty  Int        @default(0)

  sell_price   Decimal?   @db.Decimal(12, 2)
  discount     Decimal?   @db.Decimal(12, 2)
  line_total   Decimal?   @db.Decimal(14, 2)

  status       ItemStatus @default(pending)
  unexpected   Boolean    @default(false)

  version      Int        @default(0)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  receipt      Receipt    @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  evidences    Evidence[]
  logs         ScanLog[]
  shareTokens  ShareToken[]

  @@index([receipt_id])
  @@index([tenant_id, company_id, sku])
  @@index([tenant_id, company_id, barcode])
}

model Evidence {
  id         String       @id @default(uuid()) @db.Uuid
  tenant_id  String       @db.Uuid
  company_id String       @db.Uuid
  receipt_id String       @db.Uuid
  item_id    String?      @db.Uuid

  type       EvidenceType @default(photo)
  file_url   String
  file_size  Int?
  mime_type  String?
  checksum   String?
  created_by String?
  created_at DateTime     @default(now())

  receipt    Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item       ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
  @@index([item_id])
}

model ScanLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid
  receipt_id String   @db.Uuid
  item_id    String?  @db.Uuid

  user_id    String?
  device_id  String?
  action     String
  before     Json?
  after      Json?
  note       String?
  created_at DateTime @default(now())

  receipt    Receipt     @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item       ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id, created_at])
  @@index([item_id])
}

model ShareToken {
  id             String          @id @default(uuid()) @db.Uuid
  tenant_id       String          @db.Uuid
  company_id      String          @db.Uuid
  receipt_id      String          @db.Uuid
  item_id         String?         @db.Uuid

  token           String          @unique
  scope           ShareScope      @default(receipt)
  permission      SharePermission @default(read)
  active          Boolean         @default(true)
  expires_at      DateTime?
  created_at      DateTime        @default(now())

  receipt         Receipt         @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item            ReceiptItem?    @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
}

model ImportBatch {
  id         String       @id @default(uuid()) @db.Uuid
  tenant_id  String       @db.Uuid
  company_id String       @db.Uuid
  receipt_id String       @db.Uuid

  status     ImportStatus @default(draft)
  file_name  String?
  file_hash  String?

  total_rows Int          @default(0)
  valid_rows Int          @default(0)
  error_rows Int          @default(0)

  created_by String?
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  receipt    Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  exceptions ImportException[]

  @@index([receipt_id])
}

model ImportException {
  id         String   @id @default(uuid()) @db.Uuid
  batch_id   String   @db.Uuid
  row_number Int
  field      String?
  message    String
  created_at DateTime @default(now())

  batch      ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@index([batch_id])
}

model ExportJob {
  id         String    @id @default(uuid()) @db.Uuid
  tenant_id  String    @db.Uuid
  company_id String    @db.Uuid
  kind       String
  status     JobStatus @default(pending)
  file_url   String?
  created_by String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([tenant_id, company_id, status])
}

model IdempotencyRecord {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  company_id    String   @db.Uuid
  key           String
  route         String
  request_hash  String
  response_status Int?
  response_body Json?
  created_at    DateTime @default(now())

  @@unique([tenant_id, company_id, key])
  @@index([tenant_id, company_id, created_at])
}

model MasterReceipt {
  id         String       @id @default(uuid()) @db.Uuid
  tenant_id  String       @db.Uuid
  company_id String       @db.Uuid
  master_no  String
  status     MasterStatus @default(draft)

  created_by String?
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  sources    MasterReceiptSource[]
  shareLinks MasterShareLink[]

  @@unique([tenant_id, company_id, master_no])
}

model MasterReceiptSource {
  id         String   @id @default(uuid()) @db.Uuid
  master_id  String   @db.Uuid
  receipt_id String   @db.Uuid
  created_at DateTime @default(now())

  master     MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)
  receipt    Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@unique([master_id, receipt_id])
  @@index([master_id])
  @@index([receipt_id])
}

model MasterShareLink {
  id             String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid
  company_id      String   @db.Uuid
  master_id       String   @db.Uuid
  share_public_id String   @unique

  active          Boolean  @default(true)
  expires_at      DateTime?
  created_by      String?
  created_at      DateTime @default(now())

  master          MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  @@index([master_id])
}
