generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  worker
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
}

model Tenant {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  created_at DateTime  @default(now())

  companies  Company[]
  users      User[]
  receipts   Receipt[]
  masters    MasterReceipt[]
}

model Company {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  name        String
  created_at  DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  users       User[]
  receipts    Receipt[]        // ✅ 反向字段在 Receipt.company
  masterReceipts MasterReceipt[] // ✅ 反向字段在 MasterReceipt.company
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid

  user_id    String
  name       String
  role       UserRole @default(worker)
  active     Boolean  @default(true)

  created_at DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, user_id])
}

model Receipt {
  id               String        @id @default(uuid()) @db.Uuid
  tenant_id        String        @db.Uuid
  company_id       String        @db.Uuid

  receipt_no       String
  supplier_name    String?
  status           ReceiptStatus @default(pending)
  locked           Boolean       @default(false)

  public_share_id  String?       @unique

  total_items      Int           @default(0)
  completed_items  Int           @default(0)
  progress_percent Float         @default(0)

  last_activity_at DateTime      @default(now())
  created_by       String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company          Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)

  items            ReceiptItem[]
  evidences        Evidence[]
  logs             ScanLog[]
  masterSources    MasterReceiptSource[]
  importBatches    ImportBatch[]

  @@unique([tenant_id, company_id, receipt_no])
  @@index([tenant_id, company_id])
}

model ReceiptItem {
  id          String     @id @default(uuid()) @db.Uuid
  tenant_id   String     @db.Uuid
  company_id  String     @db.Uuid
  receipt_id  String     @db.Uuid

  sku         String
  barcode     String?
  name_zh     String?
  name_es     String?

  case_pack   Int?
  expected_qty Int      @default(0)
  good_qty     Int      @default(0)
  damaged_qty  Int      @default(0)

  // ✅ Postgres 用 Decimal + @db.Decimal，不要用 @db.Numeric
  sell_price  Decimal?  @db.Decimal(12, 2)
  discount    Decimal?  @db.Decimal(12, 2)
  line_total  Decimal?  @db.Decimal(14, 2)

  status      ItemStatus @default(pending)
  unexpected  Boolean    @default(false)

  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  receipt     Receipt    @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  evidences   Evidence[]
  scanLogs    ScanLog[]
  shareTokens ShareToken[]

  @@unique([receipt_id, sku])
  @@index([receipt_id])
  @@index([barcode])
}

model Evidence {
  id         String       @id @default(uuid()) @db.Uuid
  tenant_id  String       @db.Uuid
  company_id String       @db.Uuid
  receipt_id String       @db.Uuid
  item_id    String?      @db.Uuid

  type       EvidenceType @default(photo)
  file_url   String
  file_size  Int?
  mime_type  String?
  checksum   String?
  created_by String?
  created_at DateTime     @default(now())

  receipt    Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item       ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
  @@index([item_id])
}

model ScanLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid
  receipt_id String   @db.Uuid
  item_id    String?  @db.Uuid

  action     String
  barcode    String?
  sku        String?
  message    String?
  device_id  String?
  created_by String?

  created_at DateTime @default(now())

  receipt    Receipt     @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item       ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
  @@index([item_id])
}

model ImportBatch {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid
  receipt_id String?  @db.Uuid

  file_name  String?
  status     String   @default("validated")
  errors_json Json?
  created_by String?
  created_at DateTime @default(now())

  receipt    Receipt? @relation(fields: [receipt_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
}

model MasterReceipt {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  company_id String   @db.Uuid

  master_no  String
  status     String   @default("draft")

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  sources    MasterReceiptSource[]
  shareLinks MasterShareLink[]

  @@unique([tenant_id, company_id, master_no])
  @@index([tenant_id, company_id])
}

model MasterReceiptSource {
  id         String   @id @default(uuid()) @db.Uuid
  master_id  String   @db.Uuid
  receipt_id String   @db.Uuid
  created_at DateTime @default(now())

  master     MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)
  receipt    Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@unique([master_id, receipt_id])
  @@index([receipt_id])
}

model MasterShareLink {
  id             String   @id @default(uuid()) @db.Uuid
  tenant_id       String  @db.Uuid
  company_id      String  @db.Uuid
  master_id       String  @db.Uuid

  share_public_id String  @unique
  active          Boolean @default(true)
  expires_at      DateTime?

  created_by      String?
  created_at      DateTime @default(now())

  tenant          Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company         Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  master          MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  @@index([master_id])
}

model IdempotencyRecord {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id        String  @db.Uuid
  company_id       String  @db.Uuid
  idempotency_key  String
  request_hash     String
  response_status  Int?
  response_body    Json?
  created_at       DateTime @default(now())

  @@unique([tenant_id, company_id, idempotency_key])
}

model ShareToken {
  id             String   @id @default(uuid()) @db.Uuid
  tenant_id       String  @db.Uuid
  company_id      String  @db.Uuid
  receipt_id      String? @db.Uuid
  item_id         String? @db.Uuid

  public_share_id String  @unique
  active          Boolean @default(true)
  expires_at      DateTime?
  created_at      DateTime @default(now())

  receipt         Receipt?    @relation(fields: [receipt_id], references: [id], onDelete: SetNull)
  item            ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([receipt_id])
  @@index([item_id])
}
