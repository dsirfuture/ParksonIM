generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
  video
}

enum ShareTokenType {
  worker_receipt
  customer_receipt
  customer_item
}

enum SharePermission {
  edit
  read_only
}

enum UserRole {
  admin
  worker
  customer
}

enum ImportBatchStatus {
  draft
  validated
  committed
}

enum ExportJobStatus {
  pending
  running
  completed
  failed
}

enum MasterStatus {
  draft
  completed
}

model Receipt {
  id               String        @id @default(uuid()) @db.Uuid
  tenant_id         String
  company_id        String

  receipt_no        String
  supplier_name     String?

  status            ReceiptStatus @default(pending)
  total_items       Int           @default(0)
  completed_items   Int           @default(0)
  progress_percent  Float         @default(0)

  created_at        DateTime      @default(now())
  created_by        String
  last_activity_at  DateTime      @default(now())

  locked            Boolean       @default(false)
  version           Int           @default(0)

  // 用于“公开证据页”（不需要 Header 密钥，但 URL 本身是不可猜的随机串）
  public_share_id   String?       @unique

  items             ReceiptItem[]
  evidences         Evidence[]
  logs              ScanLog[]
  shareTokens       ShareToken[]

  master_sources    MasterReceiptSource[]

  @@unique([tenant_id, company_id, receipt_no])
  @@index([tenant_id, company_id, status])
  @@index([tenant_id, company_id, last_activity_at])
}

model ReceiptItem {
  id              String     @id @default(uuid()) @db.Uuid
  tenant_id        String
  company_id       String

  receipt_id       String     @db.Uuid
  receipt          Receipt    @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  sku              String
  barcode          String
  name_zh          String
  name_es          String

  // 你的“中包数”
  case_pack        Int?

  expected_qty     Int
  good_qty         Int        @default(0)
  damaged_qty      Int        @default(0)

  // 不在验货单里实际到货（unexpected=true），不定价
  unexpected       Boolean    @default(false)

  // 金额相关（注意：这里必须用 @db.Decimal，不要用 @db.Numeric）
  sell_price       Decimal?   @db.Decimal(12, 2)
  discount         Decimal?   @db.Decimal(12, 2)
  line_total       Decimal?   @db.Decimal(14, 2)

  status           ItemStatus @default(pending)
  locked           Boolean    @default(false)

  last_updated_at  DateTime   @default(now())
  last_updated_by  String?

  evidence_count   Int        @default(0)
  version          Int        @default(0)

  evidences        Evidence[]
  logs             ScanLog[]
  shareTokens      ShareToken[]

  @@unique([tenant_id, company_id, receipt_id, sku])
  @@index([tenant_id, company_id, receipt_id])
  @@index([tenant_id, company_id, sku])
  @@index([tenant_id, company_id, barcode])
}

model Evidence {
  id         String       @id @default(uuid()) @db.Uuid
  tenant_id   String
  company_id  String

  receipt_id  String       @db.Uuid
  item_id     String?      @db.Uuid

  type        EvidenceType
  file_url    String
  file_size   Int
  mime_type   String
  checksum    String

  created_at  DateTime     @default(now())
  created_by  String

  // 你要求“证据可公开浏览”
  is_public   Boolean      @default(true)

  receipt     Receipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item        ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id, receipt_id])
  @@index([tenant_id, company_id, item_id])
}

model ScanLog {
  id          String      @id @default(uuid()) @db.Uuid
  tenant_id    String
  company_id   String

  receipt_id   String      @db.Uuid
  item_id      String?     @db.Uuid

  action_type  String
  before_value Json?
  after_value  Json?

  operator_id  String
  device_id    String?
  created_at   DateTime    @default(now())

  receipt      Receipt     @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item         ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id, receipt_id])
  @@index([tenant_id, company_id, item_id])
  @@index([tenant_id, company_id, created_at])
}

model ShareToken {
  id          String          @id @default(uuid()) @db.Uuid
  tenant_id    String
  company_id   String

  token       String          @unique
  type        ShareTokenType
  permission  SharePermission

  receipt_id  String          @db.Uuid
  item_id     String?         @db.Uuid

  expires_at  DateTime?
  active      Boolean         @default(true)

  created_at  DateTime        @default(now())
  created_by  String

  receipt     Receipt         @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  item        ReceiptItem?    @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, company_id, receipt_id])
  @@index([tenant_id, company_id, token])
}

model User {
  id          String   @id
  tenant_id    String
  company_id   String

  role        UserRole
  name        String
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  @@index([tenant_id, company_id])
}

model IdempotencyRecord {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id      String
  company_id     String

  key           String
  request_hash  String
  response_body Json
  response_status Int

  created_at    DateTime @default(now())

  @@unique([tenant_id, company_id, key])
  @@index([created_at])
}

model ImportBatch {
  id               String            @id @default(uuid()) @db.Uuid
  tenant_id         String
  company_id        String

  receipt_id        String            @db.Uuid
  receipt           Receipt           @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  status            ImportBatchStatus @default(draft)
  original_filename String?
  created_at        DateTime          @default(now())
  created_by        String
  committed_at      DateTime?

  errors            ImportException[]

  @@index([tenant_id, company_id, receipt_id])
}

model ImportException {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id    String
  company_id   String

  batch_id    String   @db.Uuid
  batch       ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  row_number  Int
  field       String
  message     String
  created_at  DateTime @default(now())

  @@index([tenant_id, company_id, batch_id])
}

model ExportJob {
  id          String         @id @default(uuid()) @db.Uuid
  tenant_id    String
  company_id   String

  type        String
  status      ExportJobStatus @default(pending)

  file_url    String?
  created_at  DateTime        @default(now())
  created_by  String
}

model MasterReceipt {
  id           String       @id @default(uuid()) @db.Uuid
  tenant_id     String
  company_id    String

  master_no    String
  status       MasterStatus @default(draft)

  created_at   DateTime     @default(now())
  created_by   String

  // 公开总账单链接用（无需 Header 密钥）
  public_share_id String?   @unique

  sources      MasterReceiptSource[]
  shareLinks   MasterShareLink[]

  @@unique([tenant_id, company_id, master_no])
  @@index([tenant_id, company_id, created_at])
}

model MasterReceiptSource {
  id          String       @id @default(uuid()) @db.Uuid
  tenant_id    String
  company_id   String

  master_id   String       @db.Uuid
  receipt_id  String       @db.Uuid

  created_at  DateTime     @default(now())

  master      MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)
  receipt     Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, company_id, master_id, receipt_id])
  @@index([tenant_id, company_id, master_id])
  @@index([tenant_id, company_id, receipt_id])
}

model MasterShareLink {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id      String
  company_id     String

  share_public_id String @unique

  master_id      String  @db.Uuid
  master         MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  active        Boolean  @default(true)
  expires_at    DateTime?
  created_at    DateTime @default(now())
  created_by    String

  @@index([tenant_id, company_id, master_id])
}
