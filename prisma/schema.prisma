// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReceiptStatus {
  pending
  in_progress
  completed
}

enum ItemStatus {
  pending
  in_progress
  completed
}

enum EvidenceType {
  photo
  video
}

enum ShareTokenType {
  worker_receipt
  customer_receipt
  customer_item
  public_evidence     // ✅ 公开证据页（不需要密钥也行，但保留类型方便扩展）
  public_master       // ✅ 公开总账单
}

enum SharePermission {
  edit
  read_only
}

enum UserRole {
  admin
  worker
  customer
}

model Receipt {
  id               String       @id @default(uuid())
  tenant_id        String
  company_id       String

  receipt_no       String       @unique
  supplier_name    String?
  status           ReceiptStatus @default(pending)

  total_items      Int          @default(0)
  completed_items  Int          @default(0)
  progress_percent Float        @default(0)

  created_at       DateTime     @default(now())
  created_by       String?
  last_activity_at DateTime     @default(now())

  locked           Boolean      @default(false)
  version          Int          @default(0)

  items            ReceiptItem[]
  evidences        Evidence[]
  logs             ScanLog[]

  @@index([tenant_id, company_id])
  @@index([tenant_id, company_id, receipt_no])
}

model ReceiptItem {
  id              String    @id @default(uuid())
  tenant_id       String
  company_id      String

  receipt_id      String
  receipt         Receipt   @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  sku             String
  barcode         String
  name_zh         String?
  name_es         String?

  // 你新增的数据维度
  case_pack       Int       @default(1)   // 中包数
  expected_qty    Int       @default(0)   // 商品总数量（应验）
  sell_price      Decimal?  @db.Decimal(12, 2)
  discount        Decimal?  @db.Decimal(12, 2)
  line_total      Decimal?  @db.Decimal(12, 2)

  // 验货结果
  good_qty        Int       @default(0)
  damaged_qty     Int       @default(0)

  status          ItemStatus @default(pending)
  locked          Boolean   @default(false)
  last_updated_at DateTime  @default(now())
  last_updated_by String?
  evidence_count  Int       @default(0)

  unexpected      Boolean   @default(false) // ✅ 非清单到货商品

  version         Int       @default(0)

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([sku])
  @@index([barcode])
  @@unique([tenant_id, company_id, receipt_id, sku])
}

model Evidence {
  id          String      @id @default(uuid())
  tenant_id   String
  company_id  String

  receipt_id  String
  receipt     Receipt     @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  item_id     String?
  item        ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  type        EvidenceType
  file_url    String
  file_size   Int?
  mime_type   String?
  checksum    String?

  created_at  DateTime    @default(now())
  created_by  String?

  @@index([tenant_id, company_id])
  @@index([receipt_id])
  @@index([item_id])
}

model ScanLog {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String

  receipt_id  String
  receipt     Receipt  @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  item_id     String?
  item        ReceiptItem? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  action_type String
  before_value Json?
  after_value  Json?

  operator_id String?
  device_id   String?

  created_at  DateTime @default(now())

  @@index([tenant_id, company_id])
  @@index([receipt_id, created_at])
  @@index([item_id, created_at])
}

model ShareToken {
  id          String         @id @default(uuid())
  tenant_id   String
  company_id  String

  token       String         @unique
  type        ShareTokenType

  receipt_id  String?
  item_id     String?

  permission  SharePermission @default(read_only)

  expires_at  DateTime?
  active      Boolean        @default(true)

  created_at  DateTime       @default(now())
  created_by  String?

  @@index([tenant_id, company_id])
  @@index([receipt_id])
}

model User {
  id         String   @id
  tenant_id  String
  company_id String

  role       UserRole
  name       String
  active     Boolean  @default(true)

  created_at DateTime @default(now())

  @@index([tenant_id, company_id])
}

model IdempotencyRecord {
  id            String   @id @default(uuid())
  tenant_id     String
  company_id    String

  key           String   // Idempotency-Key
  request_hash  String?  // 可选：请求体 hash，用来更严谨防重复
  response_code Int?
  response_body Json?

  created_at    DateTime @default(now())

  @@index([tenant_id, company_id])
  @@unique([tenant_id, company_id, key])
}

//
// ===== 合并总账单（MasterReceipt） =====
//
model MasterReceipt {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String

  master_no   String   @unique
  status      String   @default("draft")

  created_at  DateTime @default(now())
  created_by  String?

  sources     MasterReceiptSource[]
  shareLinks  MasterShareLink[]

  @@index([tenant_id, company_id])
}

model MasterReceiptSource {
  id            String       @id @default(uuid())
  tenant_id     String
  company_id    String

  master_id     String
  master        MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  receipt_id    String
  receipt       Receipt       @relation(fields: [receipt_id], references: [id], onDelete: Restrict)

  created_at    DateTime      @default(now())

  @@index([tenant_id, company_id])
  @@unique([tenant_id, company_id, master_id, receipt_id])
}

model MasterShareLink {
  id              String       @id @default(uuid())
  tenant_id       String
  company_id      String

  share_public_id String       @unique
  master_id       String
  master          MasterReceipt @relation(fields: [master_id], references: [id], onDelete: Cascade)

  active          Boolean      @default(true)
  expires_at      DateTime?

  created_at      DateTime     @default(now())
  created_by      String?

  @@index([tenant_id, company_id])
  @@index([master_id])
}

//
// ===== Excel 导入批次（两阶段 validate/commit） =====
//
model ImportBatch {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String

  receipt_id  String?
  receipt_no  String?
  supplier_name String?

  status      String   @default("validated") // validated/committed/failed
  file_name   String?
  row_count   Int      @default(0)

  created_at  DateTime @default(now())
  created_by  String?

  exceptions  ImportException[]

  @@index([tenant_id, company_id])
}

model ImportException {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String

  batch_id    String
  batch       ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  row_no      Int
  field       String?
  message     String

  created_at  DateTime @default(now())

  @@index([tenant_id, company_id])
  @@index([batch_id])
}
